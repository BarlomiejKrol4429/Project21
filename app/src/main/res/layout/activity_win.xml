<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".WinActivity"
    android:id="@+id/win"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/table_win">
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="10.2"
        />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:layout_weight="9.43"
        >
        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="10"/>
        <ImageView
            android:id="@+id/lid_open"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:src="@drawable/lid_open"
            android:visibility="invisible"
            android:layout_weight="8"
        />
        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="10"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:layout_weight="9.1">
        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="9"/>
        <ImageButton
            android:id="@+id/lid_closed"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@drawable/lid_closed"
            android:onClick="unlockLid"
            android:layout_weight="4.1"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="9"/>
    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="11.06"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="7"
        android:orientation="horizontal">
        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="3"/>
        <ImageButton
            android:id="@+id/lock1"
            android:layout_width="6dp"
            android:layout_height="18dp"
            android:background="@drawable/lock"
            android:onClick="unlock1"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="2.2"/>
        <ImageButton
            android:id="@+id/lock2"
            android:layout_width="6dp"
            android:layout_height="18dp"
            android:background="@drawable/lock"
            android:onClick="unlock2"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="3"/>
    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="9"/>


</LinearLayout>